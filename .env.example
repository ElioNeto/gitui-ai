# ════════════════════════════════════════════
#  GitUI-AI — Configuração da IA
# ════════════════════════════════════════════
#
#  Escolha UM provedor (prioridade: Groq > Gemini > OpenAI > Anthropic)
#
# ── OPÇÕES GRATUITAS (sem cartão de crédito) ───────────────────────
#
#  1. GROQ — Llama 3.3 70B — RECOMENDADO
#     Cadastro: https://console.groq.com
#     → Crie uma conta, vá em "API Keys" e gere uma chave
#
GROQ_API_KEY=gsk_...

#  2. Google Gemini Flash — 1.500 req/dia
#     Cadastro: https://aistudio.google.com
#     → Faça login com Google, clique em "Get API Key"
#
# GEMINI_API_KEY=AIza...

# ── OPÇÕES PAGAS ─────────────────────────────────────────────────

# OpenAI (GPT-4o-mini)
# OPENAI_API_KEY=sk-...

# Anthropic (Claude Haiku)
# ANTHROPIC_API_KEY=sk-ant-...
